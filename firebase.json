{
  "functions": {
    "source": "functions"
  },
  "hosting": {
    "public": "public",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "headers": [
      {
        "source": "**/*",
        "headers": [
          { "key": "Cache-Control", "value": "no-cache" }
        ]
      }
    ],
    "redirects": [
      {
        "source": "/support/delete-account",
        "destination": "/delete-account.html",
        "type": 301
      },
      {
        "source": "/ios",
        "destination": "https://apps.apple.com/fr/app/padelmatch-pm/id6753951970?utm_source=web&utm_medium=redirect&utm_campaign=launch",
        "type": 302
      },
      {
        "source": "/android",
        "destination": "https://play.google.com/store/apps/details?id=com.bapoto.padelmatch&utm_source=web&utm_medium=redirect&utm_campaign=launch",
        "type": 302
      },
      {
        "source": "/app",
        "destination": "/index.html#download",
        "type": 302
      }
    ],
    "rewrites": [
      { "source": "/terms",   "destination": "/terms.html" },
      { "source": "/privacy", "destination": "/privacy.html" }
    ]
  }
}

