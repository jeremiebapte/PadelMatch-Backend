rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() { return request.auth != null; }
    function uid()      { return request.auth.uid; }
    function onlyKeysChanged(allowed) {
      return request.resource.data.diff(resource.data).changedKeys().hasOnly(allowed);
    }
    function toMillis(v) {
      return (v is timestamp) ? v.toMillis()
           : (v is int)       ? v
           : (v is float)     ? int(v)
           : 0;
    }
    function userDoc() {
      return get(/databases/$(database)/documents/users/$(uid()));
    }
    function isClubAdmin(clubId) {
      return signedIn()
        && userDoc().data.role == 'club_admin'
        && userDoc().data.clubId == clubId;
    }

    match /users/{userId} {
      allow get, list: if signedIn();
      allow create: if signedIn()
        && userId == uid()
        && (request.resource.data.pseudo is string)
        && (request.resource.data.pseudoLower is string);
      allow update: if signedIn() && userId == uid()
        && onlyKeysChanged([
          'pseudo','pseudoLower',
          'avatar','niveau','notificationsEnabled',
          'nom','prenom','photoUrl','lat','lng','email',
          'createdAt','fcmToken','fcmPlatform','fcmUpdatedAt'
        ])
        && (
          !request.resource.data.diff(resource.data).changedKeys().hasAny(['createdAt'])
          || !('createdAt' in resource.data)
        );
      allow delete: if signedIn() && userId == uid();
      match /fcmTokens/{tokenId} {
        allow get, list: if signedIn() && userId == uid();
        allow create, update, delete: if signedIn() && userId == uid()
          && request.resource.data.keys().hasOnly(['platform','updatedAt'])
          && (request.resource.data.platform is string);
      }
    }

    match /usernames/{pseudoLower} {
      allow get, list: if true;
      allow create: if signedIn()
        && !exists(/databases/$(database)/documents/usernames/$(pseudoLower))
        && request.resource.data.keys().hasOnly(['uid','createdAt'])
        && request.resource.data.uid == uid();
      allow update: if false;
      allow delete: if signedIn() && resource.data.uid == uid();
    }

    match /clubs/{clubId} {
      allow get, list: if signedIn();

      allow create, delete: if false;

      allow update: if isClubAdmin(clubId)
        && resource.data.adminUid == uid()
        && request.resource.data.adminUid == resource.data.adminUid
        && request.resource.data.status == resource.data.status
        && onlyKeysChanged([
          'name','city','address','latitude','longitude',
          'logoUrl','coverUrl','phone','email','website',
          'courtsCount','description','updatedAt'
        ]);
    }

    match /availableCourts/{courtId} {
      function validCourt(d) {
        return d.clubId is string
          && d.clubName is string
          && d.dateHeure is int
          && d.durationMinutes is int
          && d.playersNeeded is int
          && d.playersMax is int
          && d.status in ['available','converted','cancelled','expired']
          && d.latitude is number
          && d.longitude is number
          && d.city is string
          && d.address is string;
      }

      allow get, list: if signedIn();

      allow create: if signedIn()
        && validCourt(request.resource.data)
        && isClubAdmin(request.resource.data.clubId);

      allow update: if signedIn()
        && validCourt(request.resource.data)
        && isClubAdmin(resource.data.clubId)
        && request.resource.data.clubId == resource.data.clubId
        && request.resource.data.clubName == resource.data.clubName;

      allow delete: if false;
    }

    match /matches/{matchId} {
      function hasValidLevel(d) {
        return (d.level  is int && d.level  >= 1 && d.level  <= 10)
            || (d.niveau is int && d.niveau >= 1 && d.niveau <= 10);
      }
      function hasValidDate(d) { return toMillis(d.dateHeure) > 0; }
      function hasValidParticipants(d) {
        return (d.participants is list)
            && d.participants.size() >= 1
            && d.participants.size() <= 4;
      }
      function isOwner() { return signedIn() && resource.data.createurUid == uid(); }

      allow get, list: if signedIn();

      allow create: if signedIn()
        && request.resource.data.createurUid == uid()
        && hasValidLevel(request.resource.data)
        && hasValidDate(request.resource.data)
        && hasValidParticipants(request.resource.data)
        && request.resource.data.participants.size() <= 3
        && uid() in request.resource.data.participants;

      // Le créateur peut modifier les métadonnées, pas 'participants'
      allow update: if signedIn() && isOwner()
        && hasValidLevel(request.resource.data)
        && hasValidDate(request.resource.data)
        && hasValidParticipants(request.resource.data)
        && request.resource.data.participants == resource.data.participants
        && onlyKeysChanged([
          'lieu','placeId','latitude','longitude','dateHeure',
          'niveau','level','description','updatedAt',
          'createdByType','createdById','clubId','clubName','sourceAvailableCourtId'
        ])
        && request.resource.data.createurUid == resource.data.createurUid;

      // Toute autre update (join/leave) interdite côté client
      allow update: if false;

      allow delete: if signedIn() && isOwner();
    }

    match /messages/{messageId} {
      allow get, list: if signedIn()
        && (resource.data.senderUid == uid() || resource.data.receiverUid == uid());
      allow create: if signedIn()
        && request.resource.data.senderUid == uid()
        && request.resource.data.receiverUid is string
        && request.resource.data.matchId is string
        && request.resource.data.text is string
        && (
             request.resource.data.timestamp is timestamp
          || request.resource.data.timestamp is int
          || request.resource.data.timestamp is float
        );
      allow update: if signedIn()
        && resource.data.senderUid == uid()
        && request.resource.data.senderUid   == resource.data.senderUid
        && request.resource.data.receiverUid == resource.data.receiverUid
        && request.resource.data.matchId     == resource.data.matchId
        && request.resource.data.timestamp   == resource.data.timestamp
        && request.resource.data.diff(resource.data).changedKeys()
             .hasOnly(['text','edited','editedAt']);
      allow delete: if signedIn()
        && (resource.data.senderUid == uid() || resource.data.receiverUid == uid());
    }

    match /userCounters/{userId} {
      allow read: if signedIn() && userId == uid();
      allow write: if false;
    }

    match /fcmTokens/{userId} {
      allow read, write: if false;
    }
  }
}
