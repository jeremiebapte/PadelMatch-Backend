rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    match /clubs/{clubId}/{fileName} {
      allow read: if true;

      allow write: if request.auth != null
        && firestore.exists(/databases/(default)/documents/clubs/$(clubId))
        && firestore.get(/databases/(default)/documents/clubs/$(clubId)).data.adminUid == request.auth.uid
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    match /avatars/{fileName} {
      allow read: if true;

      allow write: if request.auth != null
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    match /groups/{groupId}/avatar.jpg {
      allow read: if true;

      allow write: if request.auth != null
        && firestore.exists(
          /databases/(default)/documents/groups/$(groupId)
        )
        && firestore.get(
          /databases/(default)/documents/groups/$(groupId)
        ).data.ownerUid == request.auth.uid
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }
  }
}
